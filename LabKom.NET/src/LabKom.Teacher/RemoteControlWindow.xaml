<Window x:Class="LabKom.Teacher.RemoteControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remote View"
        Width="1180" Height="760"
        MinWidth="720" MinHeight="480"
        Background="#020617"
        Foreground="#E2E8F0"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#0F172A"
                BorderBrush="#334155"
                BorderThickness="0,0,0,1"
                Padding="12,9">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="PcNameText"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusText"
                               Foreground="#94A3B8"
                               FontSize="11"
                               Text="Menyiapkan view-only..." />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="ViewOnlyButton"
                            Content="View-only"
                            Padding="12,7"
                            Margin="6,0"
                            Click="ViewOnly_Click" />
                    <Button x:Name="ControlButton"
                            Content="Aktifkan kontrol"
                            Padding="12,7"
                            Margin="0,0,6,0"
                            Background="#2563EB"
                            Foreground="White"
                            Click="Control_Click" />
                    <Button Content="Stop sesi"
                            Padding="12,7"
                            Background="#B91C1C"
                            Foreground="White"
                            Click="Stop_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                x:Name="RemoteSurface"
                Background="Black"
                Focusable="True"
                MouseMove="Surface_MouseMove"
                MouseDown="Surface_MouseDown"
                MouseUp="Surface_MouseUp"
                MouseWheel="Surface_MouseWheel">
            <Image x:Name="RemoteImage"
                   Stretch="Uniform"
                   SnapsToDevicePixels="True" />
        </Border>

        <Border Grid.Row="2"
                Background="#0F172A"
                BorderBrush="#334155"
                BorderThickness="0,1,0,0"
                Padding="10,7">
            <DockPanel>
                <TextBlock x:Name="StreamText"
                           Foreground="#94A3B8"
                           Text="Menunggu frame..." />
                <TextBlock DockPanel.Dock="Right"
                           Foreground="#FBBF24"
                           Text="Kontrol hanya aktif saat jendela ini fokus. Banner terlihat di PC siswa." />
            </DockPanel>
        </Border>
    </Grid>
</Window>
