<Application x:Class="LabKom.Teacher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="BackgroundBrush" Color="#0F172A" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="#1E293B" />
            <SolidColorBrush x:Key="BorderBrush" Color="#334155" />
            <SolidColorBrush x:Key="ForegroundBrush" Color="#F1F5F9" />
            <SolidColorBrush x:Key="MutedBrush" Color="#94A3B8" />
            <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
