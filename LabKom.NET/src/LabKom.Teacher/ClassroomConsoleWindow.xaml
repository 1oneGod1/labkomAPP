<Window x:Class="LabKom.Teacher.ClassroomConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Room, Register, Lesson &amp; Assessment"
        Width="1100" Height="760"
        MinWidth="900" MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A" Foreground="#E2E8F0">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Room" Margin="0,0,0,5" />
                <TextBox x:Name="RoomNameBox" Text="Lab Komputer"
                         Padding="7" Background="#1E293B"
                         Foreground="#E2E8F0" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                <TextBlock Text="Judul Lesson" Margin="0,0,0,5" />
                <TextBox x:Name="LessonTitleBox" Text="Pembelajaran"
                         Padding="7" Background="#1E293B"
                         Foreground="#E2E8F0" />
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                <TextBlock Text="Assessment &amp; Durasi" Margin="0,0,0,5" />
                <DockPanel>
                    <TextBox x:Name="AssessmentTitleBox"
                             Text="Evaluasi" Padding="7"
                             Background="#1E293B" Foreground="#E2E8F0"
                             Width="220" />
                    <TextBox x:Name="DurationBox" Text="30"
                             Padding="7" Margin="8,0,0,0"
                             Background="#1E293B" Foreground="#E2E8F0"
                             Width="55" />
                </DockPanel>
            </StackPanel>
            <StackPanel Grid.Column="3" Orientation="Horizontal"
                        VerticalAlignment="Bottom">
                <Button Content="Mulai Lesson" Padding="12,8"
                        Margin="0,0,7,0" Click="StartLesson_Click" />
                <Button Content="Fase Mengajar" Padding="12,8"
                        Click="Teaching_Click" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Margin="0,14,0,14" Padding="12"
                Background="#1E293B" CornerRadius="7">
            <TextBlock x:Name="StatusText"
                       Text="Belum ada lesson aktif."
                       Foreground="#93C5FD" TextWrapping="Wrap" />
        </Border>

        <TabControl Grid.Row="2" Background="#0F172A"
                    Foreground="#0F172A">
            <TabItem Header="Register">
                <DataGrid x:Name="RegistrationGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True" Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PC" Binding="{Binding PcName}" Width="150" />
                        <DataGridTextColumn Header="NIS/ID" Binding="{Binding StudentCode}" Width="160" />
                        <DataGridTextColumn Header="Nama" Binding="{Binding FullName}" Width="*" />
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding TimestampUnixMs}" Width="170" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Buat Assessment">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock TextWrapping="Wrap" Foreground="#CBD5E1"
                               Text="Satu soal per baris: Pertanyaan | Pilihan A | Pilihan B | ... | nomor jawaban benar (mulai 1)" />
                    <TextBox Grid.Row="1" x:Name="QuestionsBox"
                             Margin="0,10" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Background="#111827" Foreground="#E2E8F0"
                             Text="2 + 2 = ? | 3 | 4 | 5 | 2&#x0a;Ibu kota Indonesia? | Bandung | Jakarta | Surabaya | 2" />
                    <Button Grid.Row="2"
                            Content="Mulai Assessment"
                            HorizontalAlignment="Right"
                            Padding="16,9"
                            Click="StartAssessment_Click" />
                </Grid>
            </TabItem>
            <TabItem Header="Hasil Assessment">
                <DataGrid x:Name="ResultGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True" Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PC" Binding="{Binding PcName}" Width="150" />
                        <DataGridTextColumn Header="NIS/ID" Binding="{Binding StudentCode}" Width="170" />
                        <DataGridTextColumn Header="Benar" Binding="{Binding CorrectAnswers}" Width="100" />
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalQuestions}" Width="100" />
                        <DataGridTextColumn Header="Assessment ID" Binding="{Binding AssessmentId}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,14,0,0">
            <TextBlock x:Name="AudienceText"
                       Foreground="#94A3B8"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0" />
            <Button Content="Muat Ulang" Padding="12,8"
                    Margin="0,0,8,0" Click="Refresh_Click" />
            <Button Content="Akhiri Lesson" Padding="12,8"
                    Background="#7F1D1D" Foreground="White"
                    Click="EndLesson_Click" />
        </StackPanel>
    </Grid>
</Window>
