{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Teacher": {
    "Name": "LabKom Teacher",
    "HubPort": 41235,
    "SharedSecret": "",
    "DiscoveryBroadcastIntervalSeconds": 2,
    "SharedFileRetentionHours": 24
  },
  "Security": {
    "AllowLegacySharedSecret": true,
    "AuditPath": "%LOCALAPPDATA%\\LabKom\\Audit\\security-audit.jsonl",
    "TlsPinPath": "%LOCALAPPDATA%\\LabKom\\Security\\teacher-tls-sha256.txt"
  },
  "Telemetry": {
    "OutputDirectory": "%LOCALAPPDATA%\\LabKom\\Telemetry"
  },
  "Database": {
    "ConnectionString": "Data Source=%LOCALAPPDATA%\\LabKom\\labkom.db"
  }
}
