<Window x:Class="LabKom.Teacher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LabKom.Teacher.ViewModels"
        Title="LabKom Teacher Console"
        Width="1380" Height="860"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="Foreground" Value="#E2E8F0" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ToolbarBtn}">
            <Setter Property="Background" Value="#7F1D1D" />
            <Setter Property="BorderBrush" Value="#991B1B" />
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource ToolbarBtn}">
            <Setter Property="Background" Value="#1D4ED8" />
            <Setter Property="BorderBrush" Value="#2563EB" />
        </Style>
        <Style x:Key="LiveBtn" TargetType="Button" BasedOn="{StaticResource ToolbarBtn}">
            <Setter Property="Background" Value="#7C2D12" />
            <Setter Property="BorderBrush" Value="#9A3412" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="LabKom Teacher Console" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ServerStatus}" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#7C2D12" Padding="10,4" CornerRadius="4" Margin="0,0,8,0"
                            Visibility="{Binding IsScreenBroadcasting, Converter={x:Static vm:BooleanToVisibilityConv.Instance}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#EF4444" VerticalAlignment="Center" />
                            <TextBlock Text="LIVE Broadcast" Foreground="White" FontSize="10" Margin="6,0,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Background="#1E40AF" Padding="12,6" CornerRadius="6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Online: " Foreground="#BFDBFE" />
                            <TextBlock Text="{Binding OnlineCount}" Foreground="White" FontWeight="SemiBold" />
                            <TextBlock Text=" / " Foreground="#BFDBFE" />
                            <TextBlock Text="{Binding TotalCount}" Foreground="White" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#0B1120" Padding="16,12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="🔒 Kunci Semua" Style="{StaticResource ToolbarBtn}" Command="{Binding LockAllCommand}" />
                <Button Content="🔓 Buka Kunci Semua" Style="{StaticResource ToolbarBtn}" Command="{Binding UnlockAllCommand}" />
                <Button Command="{Binding ToggleScreenBroadcastCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource LiveBtn}">
                            <Setter Property="Content" Value="🖥️ Mulai Broadcast Layar" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsScreenBroadcasting}" Value="True">
                                    <Setter Property="Content" Value="⏹ Hentikan Broadcast" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="📂 Bagikan File ke Semua" Style="{StaticResource AccentBtn}" Command="{Binding ShareFileToAllCommand}" />
                <Button Content="⏻ Shutdown Semua" Style="{StaticResource DangerBtn}" Command="{Binding ShutdownAllCommand}" />
                <Separator Margin="6,0" />
                <TextBox Text="{Binding BroadcastMessage, UpdateSourceTrigger=PropertyChanged}"
                         Width="220" Height="32" VerticalContentAlignment="Center"
                         Background="#1E293B" Foreground="#E2E8F0"
                         BorderBrush="#334155" Padding="8,0" Margin="0,0,8,0" />
                <Button Content="📢 Broadcast Chat" Style="{StaticResource AccentBtn}" Command="{Binding BroadcastChatCommand}" />
            </StackPanel>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Tile grid -->
            <ScrollViewer Grid.Column="0" Padding="16" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Students}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:StudentTileViewModel}">
                            <Border Width="240" Height="200" Margin="6" CornerRadius="10" BorderThickness="2"
                                    Background="{StaticResource SurfaceBrush}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#020617" CornerRadius="8,8,0,0">
                                        <Grid>
                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                            <TextBlock Text="Tidak ada gambar"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Row="1" Padding="10,6" Background="#0B1120" CornerRadius="0,0,8,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding PcName}" FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding StudentName, FallbackValue='(belum login)'}"
                                                           FontSize="10" Foreground="{StaticResource MutedBrush}" />
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="3" Padding="5,1" VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding StatusColor}" Opacity="0.3" />
                                                </Border.Background>
                                                <TextBlock Text="{Binding StatusLabel}" FontSize="9">
                                                    <TextBlock.Foreground>
                                                        <SolidColorBrush Color="{Binding StatusColor}" />
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftClick"
                                                  Command="{Binding DataContext.SelectStudentCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}" />
                                </Border.InputBindings>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Detail panel -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Detail PC" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedStudent}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel>
                                <Image Source="{Binding SelectedStudent.Thumbnail}"
                                       Stretch="Uniform" MaxHeight="150" Margin="0,0,0,12" />
                                <TextBlock Text="{Binding SelectedStudent.PcName}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedStudent.StudentName, FallbackValue='(belum login)'}"
                                           Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,2,0,12" />
                                <TextBlock Text="IP" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding SelectedStudent.IpAddress}" FontFamily="Consolas" FontSize="12" />
                                <TextBlock Text="MAC" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding SelectedStudent.MacAddress}" FontFamily="Consolas" FontSize="12" />

                                <TextBlock Text="Aksi" Foreground="{StaticResource MutedBrush}"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,18,0,8" />
                                <Button Content="🔒 Kunci Layar" Style="{StaticResource ToolbarBtn}"
                                        HorizontalContentAlignment="Center" Margin="0,0,0,6"
                                        Command="{Binding LockSelectedCommand}" />
                                <Button Content="🔓 Buka Kunci" Style="{StaticResource ToolbarBtn}"
                                        HorizontalContentAlignment="Center" Margin="0,0,0,6"
                                        Command="{Binding UnlockSelectedCommand}" />
                                <Button Content="📂 Kirim File ke PC ini" Style="{StaticResource AccentBtn}"
                                        HorizontalContentAlignment="Center" Margin="0,0,0,6"
                                        Command="{Binding ShareFileToSelectedCommand}" />
                                <Button Content="📡 Wake-on-LAN" Style="{StaticResource AccentBtn}"
                                        HorizontalContentAlignment="Center" Margin="0,0,0,6"
                                        Command="{Binding WakeSelectedCommand}" />
                                <Button Content="🔄 Restart" Style="{StaticResource ToolbarBtn}"
                                        HorizontalContentAlignment="Center" Margin="0,0,0,6"
                                        Command="{Binding RestartSelectedCommand}" />
                                <Button Content="⏻ Shutdown" Style="{StaticResource DangerBtn}"
                                        HorizontalContentAlignment="Center" Margin="0,0,0,6"
                                        Command="{Binding ShutdownSelectedCommand}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Foreground="{StaticResource MutedBrush}" FontSize="11" TextWrapping="Wrap"
                                   Text="Pilih salah satu PC pada grid untuk menampilkan detail dan aksi.">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedStudent}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Activity feed -->
            <Border Grid.Column="2" Background="#0B1120"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="14,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Aktivitas Live" FontSize="13" FontWeight="SemiBold" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Activities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ActivityEntryViewModel}">
                                    <Border Padding="12,8" BorderBrush="#1E293B" BorderThickness="0,0,0,1">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding PcName}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource ForegroundBrush}" />
                                                <TextBlock Grid.Column="1" Text="{Binding TimeLabel}"
                                                           FontSize="10" Foreground="{StaticResource MutedBrush}" />
                                            </Grid>
                                            <TextBlock Text="{Binding Title}" FontSize="11"
                                                       Foreground="#CBD5E1" TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0" />
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <Border CornerRadius="3" Padding="5,1" Margin="0,0,6,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding KindColor}" Opacity="0.3" />
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding KindLabel}" FontSize="9">
                                                        <TextBlock.Foreground>
                                                            <SolidColorBrush Color="{Binding KindColor}" />
                                                        </TextBlock.Foreground>
                                                    </TextBlock>
                                                </Border>
                                                <TextBlock Text="{Binding ProcessName}"
                                                           Foreground="{StaticResource MutedBrush}" FontSize="10" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" Padding="20,8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock Text="UDP Discovery · SignalR Hub @ 41235 · v0.3.0 (Phase 3)"
                       Foreground="{StaticResource MutedBrush}" FontSize="11" />
        </Border>
    </Grid>
</Window>
