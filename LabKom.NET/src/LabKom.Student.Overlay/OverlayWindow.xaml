<Window x:Class="LabKom.Student.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LabKom Lock"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Background="#0F172A"
        Cursor="None">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0B1120" Offset="0" />
                <GradientStop Color="#1E1B4B" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="700">
            <Border Width="120" Height="120" Background="#1E40AF" CornerRadius="60" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="72" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <TextBlock Text="PERHATIAN"
                       FontSize="56" FontWeight="Black"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,40,0,16" />

            <Border Background="#1E293B" Padding="32,20" CornerRadius="14" BorderBrush="#334155" BorderThickness="1">
                <TextBlock x:Name="MessageText"
                           Text="Mohon perhatian ke instruktur"
                           FontSize="22"
                           Foreground="#E2E8F0"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0">
                <Ellipse Width="10" Height="10" Fill="#3B82F6" VerticalAlignment="Center">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="PulseTransform" CenterX="5" CenterY="5" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <TextBlock Text="Layar dikunci oleh instruktur"
                           Foreground="#93C5FD"
                           FontSize="14"
                           Margin="12,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <TextBlock Text="Keyboard dan mouse dinonaktifkan sementara"
                   Foreground="#64748B" FontSize="11"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                   Margin="0,0,0,24" />
    </Grid>
</Window>
