<Window x:Class="LabKom.Student.Desktop.RemoteSessionBanner"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sesi Remote LabKom"
        Width="360" Height="92"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Background="Transparent"
        AllowsTransparency="True">
    <Border Background="#F20F172A"
            BorderBrush="#38BDF8"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Ellipse Width="12" Height="12"
                     Fill="#22C55E"
                     VerticalAlignment="Top"
                     Margin="0,4,10,0" />
            <StackPanel Grid.Column="1">
                <TextBlock x:Name="TitleText"
                           Foreground="White"
                           FontWeight="SemiBold"
                           Text="Layar sedang dilihat Guru" />
                <TextBlock x:Name="DetailText"
                           Foreground="#CBD5E1"
                           FontSize="11"
                           Margin="0,4,8,0"
                           Text="View-only" />
            </StackPanel>
            <Button Grid.Column="2"
                    Padding="9,5"
                    VerticalAlignment="Center"
                    Content="Lepas"
                    ToolTip="Emergency release Ctrl+Alt+Q"
                    Click="Release_Click" />
        </Grid>
    </Border>
</Window>
