<Window x:Class="LabKom.Student.Desktop.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pesan Instruktur - LabKom"
        Width="440" Height="520"
        MinWidth="360" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="#0F172A"
        Foreground="#E2E8F0">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Pesan Kelas" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="Pesan dari instruktur dan balasan Anda"
                       Foreground="#94A3B8" FontSize="11" Margin="0,3,0,0" />
        </StackPanel>

        <ListBox x:Name="MessageList"
                 Grid.Row="1"
                 ItemsSource="{Binding Messages}"
                 Background="#111827"
                 BorderBrush="#334155"
                 Foreground="#E2E8F0"
                 Padding="8"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="#1E293B" CornerRadius="7" Padding="10,8" Margin="0,0,0,7">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Sender}" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="{Binding Time}" Foreground="#94A3B8" FontSize="10" />
                            </Grid>
                            <TextBlock Text="{Binding Body}" TextWrapping="Wrap" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ReplyText"
                     Grid.Column="0"
                     MaxLength="2000"
                     MinHeight="36"
                     Padding="9,6"
                     VerticalContentAlignment="Center"
                     KeyDown="ReplyText_OnKeyDown" />
            <Button Grid.Column="1"
                    Content="Kirim"
                    MinWidth="76"
                    Margin="8,0,0,0"
                    Click="SendButton_OnClick" />
        </Grid>
    </Grid>
</Window>
