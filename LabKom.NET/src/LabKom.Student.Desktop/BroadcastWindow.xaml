<Window x:Class="LabKom.Student.Desktop.BroadcastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LabKom Broadcast"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Normal"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Black"
        Cursor="None">
    <Grid>
        <Image x:Name="FrameImage" Stretch="Uniform" />
        <Border VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,16,0,0"
                Background="#CC1E40AF"
                Padding="16,8"
                CornerRadius="20">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         Fill="#EF4444"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="LIVE - Layar Instruktur"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="10,0,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
